generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(uuid())
  profilePictureUrl String
  username          String   @unique
  firstName         String
  lastName          String
  createdAt         DateTime @default(now())
  email             String
  phoneNumber       String

  @@map("users")
}
