generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String         @id @default(uuid())
  profilePictureUrl String
  username          String         @unique
  firstName         String
  lastName          String
  createdAt         DateTime       @default(now())
  email             String
  phoneNumber       String
  posts             Post[]
  mentionedIn       PostMention[]
  postsLikes        PostLike[]
  postsComments     PostComment[]
  notifications     Notification[] @relation("ReceivedNotifications")
  sentNotifications Notification[] @relation("SentNotifications")

  @@map("users")
}

model Post {
  id          String        @id @default(uuid())
  authorId    String
  imageURL    String
  description String
  hashtags    PostHashtag[]
  mentions    PostMention[]
  comments    PostComment[]
  likes       PostLike[]
  createdAt   DateTime      @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model PostMention {
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

model PostHashtag {
  id     String @id @default(uuid())
  name   String
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([name])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  from      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [from], references: [id], onDelete: Cascade)

  @@unique([postId, from])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  from      String
  comment   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [from], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  fromUserId String
  postId     String
  type       String   @default("mention")
  createdAt  DateTime @default(now())
  user       User     @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("SentNotifications", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model RevokedToken {
  token     String   @id
  expiresAt DateTime
}
