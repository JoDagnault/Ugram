generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(uuid())
  profilePictureUrl String
  username          String   @unique
  firstName         String
  lastName          String
  createdAt         DateTime @default(now())
  email             String
  phoneNumber       String
  posts             Post[]

  @@map("users")
}

model Post {
  id          String   @id @default(uuid())
  authorId    String
  imageURL    String
  description String
  hashtags    String[]
  mentions    String[]
  createdAt   DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
