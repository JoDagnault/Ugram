{
    "name": "UGram",
    "version": "1.0.0",
    "description": "UGram monorepo with frontend and backend",
    "type": "module",
    "scripts": {
        "prepare": "husky install",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.28.1",
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.54.0",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^16.5.0",
        "husky": "9",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1"
    },
    "lint-staged": {
        "frontend/**/*.{ts,tsx,js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "frontend/**/*.{json,css,scss,md}": [
            "prettier --write"
        ],
        "backend/**/*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "backend/**/*.json": [
            "prettier --write"
        ]
    }
}
